{
    "version": 2,
    "builds": [
      {
        "src": "src/index.ts",
        "use": "@vercel/node",
        "config": {
          "typescript": {
            "tsconfig": "tsconfig.json"
          }
        }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/src/index.ts",
        "headers": { "Content-Type": "text/plain" }
      }
    ]
  }
  